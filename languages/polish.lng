EDITOR_UI_LEGACYOBJECT      "archaiczny obiekt"
EDITOR_UI_MISSING           "<brakuje>"

// Bricks - scenery elements
// Translators: please keep the names below succint. See the comments for their meaning.
EDITOR_BRICK_TYPE_SOLID     "SOLIDNY"     // a solid brick (you can't get inside them)
EDITOR_BRICK_TYPE_CLOUD     "CHMURA"     // "jump-through" platforms (you can step on top of them)
EDITOR_BRICK_TYPE_PASSABLE  "DEKORACYJNY"  // a cegiełka with no effect on collisions (decorative elements)
EDITOR_BRICK_TYPE_UNKNOWN   "NIEZNANY"

EDITOR_BRICK_BEHAVIOR_DEFAULT    "ZWYCZAJNY"   // a brick that stands still
EDITOR_BRICK_BEHAVIOR_CIRCULAR   "OKRĄGŁY"  // circular motion / elliptic orbit
EDITOR_BRICK_BEHAVIOR_PENDULAR   "WAHADŁOWY"  // a brick with pendular motion
EDITOR_BRICK_BEHAVIOR_BREAKABLE  "ŁAMLIWY" // breakable when rolling and colliding with it
EDITOR_BRICK_BEHAVIOR_SMASHABLE  "ROZBIJALNY" // will break when the player jumps on top of it
EDITOR_BRICK_BEHAVIOR_FALL       "SPADAJĄCY"      // falls as soon as the player steps on it
EDITOR_BRICK_BEHAVIOR_FLOAT      "PŁYWAJĄCY"     // a floating platform
EDITOR_BRICK_BEHAVIOR_MARKER     "ZAZNACZ"    // special brick only rendered in the editor
EDITOR_BRICK_BEHAVIOR_UNKNOWN    "NIEZNANY"

EDITOR_BRICK_FLIP_NOFLIP    "nieodwrócony"            // the brick is not flipped (this is the default)
EDITOR_BRICK_FLIP_HFLIP     "Odwrócony horyzontalnie" // flip horizontally
EDITOR_BRICK_FLIP_VFLIP     "Odwrócony wertykalnie"   // flip vertically
EDITOR_BRICK_FLIP_VHFLIP    "Obrócony o 180°"      // flip horizontally & vertically

// Palette
EDITOR_PALETTE_BRICK        "cegiełka"
EDITOR_PALETTE_MISSING      "brakuje"
